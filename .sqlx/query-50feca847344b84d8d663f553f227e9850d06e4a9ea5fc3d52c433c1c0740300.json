  "query": "\n            SELECT\n                a.pk_driver_mail_attachment_id,\n                a.fk_driver_mail_id,\n                d.file_name,\n                d.s3_file_path,\n                d.created_at\n            FROM driver_mail_attachments a\n            JOIN documents d ON d.pk_document_id = a.fk_document_id\n            WHERE a.pk_driver_mail_attachment_id = $1\n            ",
